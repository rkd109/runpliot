{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["node", "jest"]
  },
  // "include": ["src/**/*.ts", "prisma.config.ts"],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}